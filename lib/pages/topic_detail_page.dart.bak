      futureIcon = Icons.lock_rounded;
      themeColor = Colors.redAccent;
    } else if (_involvement > 0.3) {
      gpaText = '2.10 (犧巵ｸｲ犧吭ｸ≒ｸ･犧ｲ犧�ｸ�ｹ謂ｸｭ犧吭ｸもｹ霞ｸｲ犧�ｸ歩ｹ謂ｸｳ)';
      futureText = '犧憫ｸ･犧≒ｸｲ犧｣犹犧｣犧ｵ犧｢犧吭ｸ伶ｸ｣犧ｸ犧扉ｸｮ犧ｧ犧� 犧もｸｲ犧扉ｸｪ犧｡犧ｲ犧倨ｸｴ 犹犧｣犧ｴ犹謂ｸ｡犧ｫ犧吭ｸｵ犹犧｣犧ｵ犧｢犧吭ｸ壟ｹ謂ｸｭ犧｢犧�ｸ｣犧ｱ犹霞ｸ� 犹もｸｭ犧≒ｸｲ犧ｪ犧籾ｸｹ犧≒ｸ伶ｸｱ犧内ｸ隊ｹ呉ｸ壟ｸ吭ｸｪ犧ｹ犧�';
      futureIcon = Icons.warning_rounded;
      themeColor = Colors.amber;
    }

    return Container(
      padding: const EdgeInsets.all(12),
      decoration: BoxDecoration(
        color: widget.isDark ? const Color(0xFF0F172A) : const Color(0xFFF8FAFC),
        borderRadius: BorderRadius.circular(20),
      ),
      child: Column(
        children: [
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              Text('犧｣犧ｰ犧扉ｸｱ犧壟ｸ≒ｸｲ犧｣犹犧≒ｸｵ犹謂ｸ｢犧ｧ犧扉ｸｭ犧�ｸｪ犧ｲ犧｣犹犧ｪ犧樅ｸ歩ｸｴ犧�:', style: const TextStyle(fontSize: 10.5, fontWeight: FontWeight.bold, fontFamily: 'Prompt')),
              Text('${(_involvement * 100).toInt()}%', style: TextStyle(fontSize: 11, fontWeight: FontWeight.bold, color: themeColor, fontFamily: 'Prompt')),
            ],
          ),
          const SizedBox(height: 6),
          Slider(
            value: _involvement,
            onChanged: (v) => setState(() => _involvement = v),
            min: 0.0,
            max: 1.0,
            activeColor: themeColor,
          ),
          const SizedBox(height: 6),
          Container(
