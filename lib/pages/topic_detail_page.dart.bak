                const SizedBox(width: 4),
                _buildStepTab(2, '3. 犧ｫ犧･犧ｱ犧�ｸｫ犧｡犧扉ｸ､犧伶ｸ倨ｸｴ犹�', Icons.mood_bad_rounded, Colors.grey),
