      brainDesc = '犧ｪ犧ｲ犧｣犹犧ｪ犧樅ｸ歩ｸｴ犧扉ｹ犧もｹ霞ｸｲ犹�ｸ巵ｸ壟ｸ･犹�ｸｭ犧≒ｸ癌ｹ謂ｸｭ犧�ｸ扉ｸｹ犧扉ｸ≒ｸ･犧ｱ犧壟ｸもｸｭ犧�ｸｪ犧｡犧ｭ犧� 犧伶ｸｳ犹�ｸｫ犹霞ｹもｸ扉ｸ巵ｸｲ犧｡犧ｵ犧吭ｸ･犹霞ｸ吭ｸ伶ｸｰ犧･犧ｱ犧≒ｹ≒ｸ･犧ｰ犧≒ｸ｣犧ｰ犧歩ｸｸ犹霞ｸ吭ｸ巵ｸ｣犧ｰ犧ｪ犧ｲ犧伶ｸ｣犧ｸ犧吭ｹ≒ｸ｣犧�ｸ歩ｹ謂ｸｭ犹犧吭ｸｷ犹謂ｸｭ犧�';
      brainColor = Colors.redAccent;
