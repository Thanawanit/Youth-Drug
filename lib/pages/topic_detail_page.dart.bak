  String _getOrganDamageDesc(String organ) {
    switch (organ) {
      case '犧ｪ犧｡犧ｭ犧�':
        return '犧ｪ犧ｲ犧｣犧樅ｸｴ犧ｩ犧伶ｸｳ犧･犧ｲ犧｢犧｣犧ｰ犧壟ｸ壟ｹ犧金ｸ･犧･犹呉ｸ巵ｸ｣犧ｰ犧ｪ犧ｲ犧伶ｹもｸ扉ｸ｢犧歩ｸ｣犧� 犧ｪ犹謂ｸ�ｸ憫ｸ･犹�ｸｫ犹霞ｹ犧吭ｸｷ犹霞ｸｭ犧ｪ犧｡犧ｭ犧�ｸｪ犹謂ｸｧ犧吭ｸｫ犧吭ｹ霞ｸｲ犧杳ｹ謂ｸｭ犧歩ｸｱ犧ｧ犧籾ｸｲ犧ｧ犧｣ 犧もｸｱ犧扉ｸもｸｧ犧ｲ犧�ｸ�ｸｧ犧ｲ犧｡犧ｪ犧ｲ犧｡犧ｲ犧｣犧籾ｹ�ｸ吭ｸ≒ｸｲ犧｣犹犧｣犧ｵ犧｢犧吭ｸ｣犧ｹ犹霞ｹ≒ｸ･犧ｰ犧�ｸｧ犧ｲ犧｡犧伶ｸ｣犧�ｸ謂ｸｳ犹犧ｪ犧ｷ犹謂ｸｭ犧｡';
      case '犧ｫ犧ｱ犧ｧ犹�ｸ�':
        return '犧≒ｸ｣犧ｰ犧歩ｸｸ犹霞ｸ吭ｹ�ｸｫ犹霞ｸ≒ｸ･犹霞ｸｲ犧｡犹犧吭ｸｷ犹霞ｸｭ犧ｫ犧ｱ犧ｧ犹�ｸ謂ｸ壟ｸｵ犧壟ｸ歩ｸｱ犧ｧ犧｣犧ｸ犧吭ｹ≒ｸ｣犧�ｹ犧≒ｸｴ犧吭ｸ謂ｸ｣犧ｴ犧� 犹犹犧歩ｹ謂ｸ吭ｸｲ犧吭ｹ�ｸ巵ｸｫ犧ｱ犧ｧ犹�ｸ謂ｹもｸ� 犧憫ｸｴ犧扉ｸ謂ｸｱ犧�ｸｫ犧ｧ犧ｰ 犹犧ｪ犧ｵ犹謂ｸ｢犧�ｸｪ犧�犧ｲ犧ｧ犧ｰ犧ｫ犧ｱ犧ｧ犹�ｸ謂ｸ･犹霞ｸ｡犹犧ｫ犧･犧ｧ犹犧霞ｸｵ犧｢犧壟ｸ樅ｸ･犧ｱ犧吭ｹ犧ｪ犧ｵ犧｢犧癌ｸｵ犧ｧ犧ｴ犧歩ｸ伶ｸｱ犧吭ｸ伶ｸｵ';
      case '犧巵ｸｭ犧�':
        return '犧吭ｸｴ犹もｸ�ｸ歩ｸｴ犧吭ｹ犧ｫ犧･犧ｧ犹≒ｸ･犧ｰ犧ｪ犧ｲ犧｣犧｣犧ｰ犹犧ｫ犧｢犹犧憫ｸｲ犧伶ｸｳ犧･犧ｲ犧｢犹犧吭ｸｷ犹霞ｸｭ犹犧｢犧ｷ犹謂ｸｭ犧籾ｸｸ犧�ｸ･犧｡犧巵ｸｭ犧� 犧≒ｹ謂ｸｭ犧≒ｸｲ犧｣犧ｭ犧ｱ犧≒ｹ犧ｪ犧壟ｹ犧｣犧ｷ犹霞ｸｭ犧｣犧ｱ犧� 犧吭ｸｳ犹�ｸ巵ｸｪ犧ｹ犹謂ｹもｸ｣犧�ｸ｡犧ｰ犹犧｣犹�ｸ�ｸ巵ｸｭ犧扉ｹ≒ｸ･犧ｰ犹もｸ｣犧�ｸ籾ｸｸ犧�ｸ･犧｡犹もｸ巵ｹ謂ｸ�ｸ樅ｸｭ犧�';
      case '犧憫ｸｴ犧ｧ犧樅ｸ｣犧｣犧�/犧游ｸｱ犧�':
        return '犧ｪ犧ｲ犧｣犹犧�ｸ｡犧ｵ犧ｪ犧ｰ犧ｪ犧｡犧伶ｸｳ犹�ｸｫ犹霞ｹ犧ｪ犹霞ｸ吭ｹ犧･犧ｷ犧ｭ犧扉ｸ杳ｸｭ犧｢犧歩ｸｵ犧壟ｸ歩ｸｱ犧� 犧憫ｸｴ犧ｧ犧樅ｸ｣犧｣犧内ｸｪ犧ｹ犧財ｹ犧ｪ犧ｵ犧｢犧�ｸｧ犧ｲ犧｡犧癌ｸｷ犹霞ｸ吭ｸｫ犧｡犧ｭ犧�ｸ�ｸ･犹霞ｸｳ 犧游ｸｱ犧吭ｸ憫ｸｸ犧≒ｸ｣犹謂ｸｭ犧吭ｹ犧｣犹�ｸｧ 犹≒ｸ･犧ｰ犧≒ｸ･犧ｴ犹謂ｸ吭ｸ歩ｸｱ犧ｧ犹犧ｫ犧｡犹�ｸ吭ｸ｣犧ｸ犧吭ｹ≒ｸ｣犧�';
