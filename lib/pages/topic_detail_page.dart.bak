      brainDesc = '犧ｪ犧｡犧ｭ犧�ｸ巵ｸ｣犧ｱ犧壟ｸ歩ｸｱ犧ｧ犹もｸ扉ｸ｢犧伶ｸｳ犧･犧ｲ犧｢犧歩ｸｱ犧ｧ犧｣犧ｱ犧壟ｹもｸ扉ｸ巵ｸｲ犧｡犧ｵ犧吭ｹ≒ｸ･犧ｰ犧ｫ犧｢犧ｸ犧扉ｸ憫ｸ･犧ｴ犧歩ｸｪ犧ｲ犧｣犧ｪ犧ｸ犧もｸ癌ｸｱ犹謂ｸｧ犧�ｸ｣犧ｲ犧ｧ 犧伶ｸｳ犹�ｸｫ犹霞ｸ｣犧ｰ犧扉ｸｱ犧壟ｹもｸ扉ｸ巵ｸｲ犧｡犧ｵ犧吭ｸ扉ｸｴ犹謂ｸ�ｸ歩ｹ謂ｸｳ犧≒ｸｧ犹謂ｸｲ犧巵ｸ≒ｸ歩ｸｴ';
      brainColor = Colors.grey;
      dopamineLevel = 0.08;

      detailFeeling = '犧ｫ犧扉ｸｫ犧ｹ犹� 犧金ｸｶ犧｡犹犧ｨ犧｣犹霞ｸｲ 犧ｧ犧ｴ犧歩ｸ≒ｸ≒ｸｱ犧�ｸｧ犧･ 犧ｭ犹謂ｸｭ犧吭ｹ犧樅ｸ･犧ｵ犧｢犹�ｸ｣犹霞ｸ樅ｸ･犧ｱ犧�ｸ�ｸｲ犧� 犹≒ｸ･犧ｰ犹犧≒ｸｴ犧扉ｸｭ犧ｲ犧≒ｸｲ犧｣犹もｸｫ犧｢犧ｫ犧ｲ犹犧樅ｸｷ犹謂ｸｭ犧伶ｸｵ犹謂ｸ謂ｸｰ犹犧ｪ犧樅ｸ金ｹ霞ｸｳ';
      detailMechanism = '犧巵ｸｱ犹癌ｸ｡犧扉ｸｹ犧扉ｸ≒ｸ･犧ｱ犧壟ｸ伶ｸｳ犧�ｸｲ犧吭ｸｭ犧ｵ犧≒ｸ�ｸ｣犧ｱ犹霞ｸ�ｹ≒ｸ歩ｹ謂ｹもｸ扉ｸ巵ｸｲ犧｡犧ｵ犧吭ｹ≒ｸ伶ｸ壟ｹ�ｸ｡犹謂ｹ犧ｫ犧･犧ｷ犧ｭ 犹≒ｸ･犧ｰ犧歩ｸｱ犧ｧ犧｣犧ｱ犧壟ｸｪ犧ｲ犧｣犧ｪ犧ｸ犧もｸ･犧扉ｸ謂ｸｳ犧吭ｸｧ犧吭ｸ･犧� (Downregulation)';
      detailEffect = '犹犧≒ｸｴ犧扉ｸ�犧ｲ犧ｧ犧ｰ犧扉ｸｷ犹霞ｸｭ犧｢犧ｲ (Tolerance) 犧歩ｹ霞ｸｭ犧�ｹ犧樅ｸｴ犹謂ｸ｡犧巵ｸ｣犧ｴ犧｡犧ｲ犧内ｸｪ犧ｲ犧｣犹犧ｪ犧樅ｸ歩ｸｴ犧扉ｹ犧樅ｸｷ犹謂ｸｭ犹�ｸｫ犹霞ｹ�ｸ扉ｹ霞ｸ�ｸｧ犧ｲ犧｡犧ｪ犧ｸ犧もｹ犧伶ｹ謂ｸｲ犹犧扉ｸｴ犧｡ 犧吭ｸｳ犹�ｸ巵ｸｪ犧ｹ犹謂ｸ≒ｸｲ犧｣犧歩ｸｴ犧扉ｸ籾ｸｲ犧ｧ犧｣';
    }

    return Container(
      padding: const EdgeInsets.all(12),
      decoration: BoxDecoration(
        color: widget.isDark ? const Color(0xFF0F172A) : const Color(0xFFF8FAFC),
        borderRadius: BorderRadius.circular(20),
        border: Border.all(color: widget.isDark ? Colors.white.withOpacity(0.1) : Colors.black.withOpacity(0.05)),
      ),
      child: Column(
        children: [
          Container(
