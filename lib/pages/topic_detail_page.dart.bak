          const SizedBox(height: 8),
          Text(
            _useDrugs
                ? '犧�ｸｧ犧ｲ犧｡犧ｪ犧ｱ犧｡犧樅ｸｱ犧吭ｸ倨ｹ呉ｸ｣犹霞ｸｲ犧ｧ犧霞ｸｲ犧� 犧樅ｹ謂ｸｭ犹≒ｸ｡犹謂ｹ犧ｪ犧ｵ犧｢犧吭ｹ霞ｸｳ犧歩ｸｲ 犹犧樅ｸｷ犹謂ｸｭ犧吭ｹ� 犹≒ｸ･犧ｰ犧�ｸ｣犧ｹ犹�ｸ｡犹謂ｸｪ犧ｲ犧｡犧ｲ犧｣犧籾ｹ�ｸｫ犹霞ｸ�ｸｧ犧ｲ犧｡犹�ｸｧ犹霞ｸｧ犧ｲ犧�ｹ�ｸ謂ｹ�ｸ扉ｹ�'
                : '犧ｪ犧ｲ犧｢犧ｪ犧ｱ犧｡犧樅ｸｱ犧吭ｸ倨ｹ呉ｹ犧ｫ犧吭ｸｵ犧｢犧ｧ犹≒ｸ吭ｹ謂ｸ� 犧伶ｸｸ犧≒ｸ�ｸ吭ｸ樅ｸ｣犹霞ｸｭ犧｡犹犧�ｸｲ犧｣犧� 犧癌ｹ謂ｸｧ犧｢犹犧ｫ犧･犧ｷ犧ｭ 犹≒ｸ･犧ｰ犧歩ｹ霞ｸｭ犧吭ｸ｣犧ｱ犧壟ｸ�ｸｸ犧内ｸ扉ｹ霞ｸｧ犧｢犧�ｸｧ犧ｲ犧｡犧｣犧ｱ犧≒ｸ�ｸｧ犧ｲ犧｡犧ｭ犧壟ｸｭ犧ｸ犹謂ｸ�',
            style: TextStyle(
              fontSize: 11 * widget.fontScale,
              fontWeight: FontWeight.bold,
              color: _useDrugs ? Colors.redAccent : AppColors.success,
              fontFamily: 'Prompt',
            ),
            textAlign: TextAlign.center,
          ),
