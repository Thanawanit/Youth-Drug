    String detailFeeling = '犧�ｸｧ犧ｲ犧｡犧ｪ犧ｸ犧もｸ歩ｸｲ犧｡犧倨ｸ｣犧｣犧｡犧癌ｸｲ犧歩ｸｴ 犧ｪ犧�ｸ� 犧｡犧ｵ犧ｪ犧｡犧ｲ犧倨ｸｴ 犧｡犧ｱ犹謂ｸ吭ｸ�ｸ� 犹≒ｸ･犧ｰ犧�ｸｧ犧壟ｸ�ｸｸ犧｡犧歩ｸ吭ｹ犧ｭ犧�ｹ�ｸ扉ｹ霞ｸ扉ｸｵ犹犧｢犧ｵ犹謂ｸ｢犧｡';
    String detailMechanism = '犧ｪ犧｡犧ｭ犧�ｸｫ犧･犧ｱ犹謂ｸ�ｸｪ犧ｲ犧｣犧ｪ犧ｸ犧もｹもｸ扉ｸ巵ｸｲ犧｡犧ｵ犧吭ｹ≒ｸ･犧ｰ犧｣犧ｰ犧壟ｸｲ犧｢犧≒ｸ･犧ｱ犧壟ｸ伶ｸｲ犧�ｸ癌ｹ謂ｸｭ犧�ｸ扉ｸｹ犧扉ｸ≒ｸ･犧ｱ犧壟ｸ歩ｸｲ犧｡犧倨ｸ｣犧｣犧｡犧癌ｸｲ犧歩ｸｴ 犹犧樅ｸｷ犹謂ｸｭ犧�ｸｧ犧壟ｸ�ｸｸ犧｡犹�ｸ｡犹謂ｹ�ｸｫ犹霞ｸ歩ｸｷ犹謂ｸ吭ｸ歩ｸｱ犧ｧ犹犧≒ｸｴ犧吭ｸもｸ吭ｸｲ犧�';
    String detailEffect = '犧樅ｸｱ犧亭ｸ吭ｸｲ犧ｪ犧｡犧ｭ犧�ｸｪ犹謂ｸｧ犧吭ｸｫ犧吭ｹ霞ｸｲ 犹犧ｪ犧｣犧ｴ犧｡犧ｪ犧｡犧ｲ犧倨ｸｴ 犧�ｸｧ犧ｲ犧｡犧�ｸｴ犧扉ｸｪ犧｣犹霞ｸｲ犧�ｸｪ犧｣犧｣犧�ｹ� 犹≒ｸ･犧ｰ犧≒ｸｲ犧｣犧�ｸｧ犧壟ｸ�ｸｸ犧｡犧ｭ犧ｲ犧｣犧｡犧内ｹ呉ｹ�ｸ吭ｸ｣犧ｰ犧｢犧ｰ犧｢犧ｲ犧ｧ';

    if (_currentStep == 1) {
