          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              const Text('犧ｪ犧籾ｸｲ犧吭ｸ≒ｸｲ犧｣犧内ｹ呉ｹ�ｸ吭ｸ癌ｸｵ犧ｧ犧ｴ犧歩ｸ�ｸｸ犧�:', style: TextStyle(fontSize: 11, fontWeight: FontWeight.bold, fontFamily: 'Prompt')),
              Switch(
                value: _useDrugs,
                onChanged: (v) => setState(() => _useDrugs = v),
                activeColor: Colors.redAccent,
              ),
            ],
          ),
          const SizedBox(height: 8),
          Container(
            height: 180,
