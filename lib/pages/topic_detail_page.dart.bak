      detailFeeling = '犧歩ｸｷ犹謂ｸ吭ｸ歩ｸｱ犧ｧ犧ｪ犧ｸ犧扉ｸもｸｵ犧� 犹犧�ｸ･犧ｴ犧壟ｹ犧�ｸ･犧ｴ犹霞ｸ｡ 犧ｪ犧ｸ犧もｸ癌ｸｱ犹謂ｸｧ犧�ｸ｣犧ｲ犧ｧ犹≒ｸ壟ｸ壟ｸ･犹霞ｸ吭ｸ伶ｸｰ犧･犧ｱ犧� 犹≒ｸ･犧ｰ犧ｫ犧ｱ犧ｧ犹�ｸ謂ｹ犧歩ｹ霞ｸ吭ｹ犧｣犹�ｸｧ犧憫ｸｴ犧扉ｸ巵ｸ≒ｸ歩ｸｴ';
      detailMechanism = '犹もｸ｡犹犧･犧≒ｸｸ犧･犧｢犧ｲ犹犧ｪ犧樅ｸ歩ｸｴ犧扉ｸ壟ｸ･犹�ｸｭ犧≒ｸ巵ｸｱ犹癌ｸ｡犧扉ｸｹ犧扉ｸ≒ｸ･犧ｱ犧� 犧伶ｸｳ犹�ｸｫ犹霞ｹもｸ扉ｸ巵ｸｲ犧｡犧ｵ犧吭ｸ歩ｸｴ犧扉ｸ�ｹ霞ｸｲ犧�ｸｭ犧｢犧ｹ犹謂ｹ�ｸ吭ｸ癌ｹ謂ｸｭ犧�ｸｧ犹謂ｸｲ犧�ｹ≒ｸ･犧ｰ犧≒ｸ｣犧ｰ犧歩ｸｸ犹霞ｸ吭ｸ歩ｸｱ犧ｧ犧｣犧ｱ犧壟ｹ�ｸ｡犹謂ｸｫ犧｢犧ｸ犧扉ｸｫ犧｢犹謂ｸｭ犧�';
      detailEffect = '犧ｪ犧｡犧ｭ犧�ｹ犧｣犧ｴ犹謂ｸ｡犹犧ｪ犧ｷ犹謂ｸｭ犧｡犹≒ｸ･犧ｰ犧癌ｸｴ犧吭ｸ≒ｸｱ犧壟ｹ≒ｸ｣犧�ｸ≒ｸ｣犧ｰ犧歩ｸｸ犹霞ｸ吭ｸ伶ｸｵ犹謂ｸ｣犧ｸ犧吭ｹ≒ｸ｣犧� 犧伶ｸｳ犹�ｸｫ犹霞ｸ≒ｸｴ犧謂ｸ≒ｸ｣犧｣犧｡犧巵ｸ≒ｸ歩ｸｴ犹�ｸ吭ｸ癌ｸｵ犧ｧ犧ｴ犧歩ｸ巵ｸ｣犧ｰ犧謂ｸｳ犧ｧ犧ｱ犧吭ｹ�ｸ｡犹謂ｸｪ犧ｲ犧｡犧ｲ犧｣犧籾ｸｪ犧｣犹霞ｸｲ犧�ｸ�ｸｧ犧ｲ犧｡犧ｪ犧ｸ犧もｹ�ｸ扉ｹ霞ｸｭ犧ｵ犧�';
    } else if (_currentStep == 2) {
